# tt-warp shell integration — source this from .bashrc or .zshrc
# Provides: hardware status chip in prompt, tmux status bar, auto-env hints

_TT_STATE="$HOME/.tt-warp/state.json"
_TT_STATE_MAX_AGE=30  # seconds before re-running tt-smi
: "${TT_WARP_AUTO_ENV:=suggest}"  # suggest | auto | off

# ── State reader ─────────────────────────────────────────────────────────────

_tt_read_state() {
    # Returns: populates _TT_DEVICES _TT_ENV _TT_LLM _TT_TEMP
    _TT_DEVICES="" _TT_ENV="" _TT_LLM="" _TT_TEMP=""
    [[ ! -f "$_TT_STATE" ]] && return

    local now age
    now=$(date +%s)
    age=$(( now - $(stat -c %Y "$_TT_STATE" 2>/dev/null || echo 0) ))
    if (( age > _TT_STATE_MAX_AGE )); then
        # Refresh in background; use stale data this render
        ( tt-smi -s 2>/dev/null | python3 -c "
import json, sys, time, pathlib, os
try:
    data = json.load(sys.stdin)
    devs = data.get('device_info', [])
    state = {
        'hardware': {'devices': [
            {'type': d.get('board_info',{}).get('board_type','?').upper(),
             'temperature': d.get('telemetry',{}).get('asic_temperature',0)}
            for d in devs
        ], 'count': len(devs)},
        'timestamp': time.time()
    }
    p = pathlib.Path(os.path.expanduser('~/.tt-warp/state.json'))
    p.parent.mkdir(exist_ok=True)
    p.write_text(json.dumps(state))
except Exception:
    pass
" & )
    fi

    # Parse stale-or-fresh state.json with python (handles JSON correctly)
    local parsed
    parsed=$(python3 -c "
import json, sys
try:
    s = json.load(open('$_TT_STATE'))
    hw = s.get('hardware') or {}
    devs = hw.get('devices', [])
    types = list(dict.fromkeys(d['type'] for d in devs))
    temps = [d.get('temperature',0) for d in devs if d.get('temperature',0) > 0]
    max_temp = max(temps) if temps else 0
    env = s.get('env') or ''
    llm = (s.get('llm') or {}).get('active_model') or ''
    print(f'{\"|\" .join(types)}|{env}|{llm}|{max_temp:.0f}')
except Exception:
    print('|||')
" 2>/dev/null)
    IFS='|' read -r _TT_DEVICES _TT_ENV _TT_LLM _TT_TEMP <<< "$parsed"
}

# ── Colour helpers ────────────────────────────────────────────────────────────

_tt_color() { printf '\[\e[%sm\]' "$1"; }
_TEAL=$(_tt_color "36")     # healthy chip
_YELLOW=$(_tt_color "33")   # warm chip
_RED=$(_tt_color "31")      # error
_PINK=$(_tt_color "35")     # env name
_GREEN=$(_tt_color "32")    # LLM live
_RESET=$(_tt_color "0")

# ── Chip rendering ────────────────────────────────────────────────────────────

_tt_chip_color() {
    local temp="$1"
    if (( temp >= 85 )); then echo "$_RED"
    elif (( temp >= 70 )); then echo "$_YELLOW"
    else echo "$_TEAL"
    fi
}

_tt_prompt_chip() {
    _tt_read_state
    [[ -z "$_TT_DEVICES" ]] && return

    local chip_color
    chip_color=$(_tt_chip_color "${_TT_TEMP:-0}")
    local chip="${chip_color}⬡${_TT_DEVICES}${_RESET}"
    local env_part=""
    [[ -n "$_TT_ENV" ]] && env_part=" ${_PINK}${_TT_ENV}${_RESET}"
    local llm_part=""
    [[ -n "$_TT_LLM" ]] && llm_part=" ${_GREEN}●${_TT_LLM}${_RESET}"
    local temp_part=""
    (( ${_TT_TEMP:-0} >= 70 )) && temp_part=" ${_YELLOW}${_TT_TEMP}°C${_RESET}"

    echo "${chip}${env_part}${llm_part}${temp_part}"
}

# ── Auto-env detection ────────────────────────────────────────────────────────

_tt_check_env() {
    [[ "$TT_WARP_AUTO_ENV" == "off" ]] && return
    local hint=""
    if [[ -f ".tt-env" ]]; then
        hint=$(cat .tt-env)
    elif grep -qsE "tt_lib|tt_forge|import forge" pyproject.toml setup.py 2>/dev/null; then
        hint="forge"
    elif grep -qsE "tt_metal|import ttnn" pyproject.toml setup.py 2>/dev/null; then
        hint="metal"
    fi
    [[ -z "$hint" ]] && return

    local current
    current=$(python3 -c "
import os,pathlib
ve=os.environ.get('VIRTUAL_ENV','')
print(pathlib.Path(ve).name if ve else '')
" 2>/dev/null)

    [[ "$current" == *"$hint"* ]] && return  # already active

    if [[ "$TT_WARP_AUTO_ENV" == "suggest" ]]; then
        echo "tt-warp: detected ${hint} project — run 'tt env activate ${hint}' to activate"
    elif [[ "$TT_WARP_AUTO_ENV" == "auto" ]]; then
        local snippet
        snippet=$(tt-mcp-server --activate-env "$hint" 2>/dev/null)
        [[ -n "$snippet" ]] && eval "$snippet"
    fi
}

# ── PROMPT_COMMAND integration ────────────────────────────────────────────────

_tt_update_prompt() {
    local chip
    chip=$(_tt_prompt_chip)
    if [[ -n "$chip" ]]; then
        PS1="${chip}\n${PS1_BASE:-\\$ }"
    else
        PS1="${PS1_BASE:-\\$ }"
    fi

    # tmux status-right update
    if [[ -n "$TMUX" && -n "$_TT_DEVICES" ]]; then
        local tmux_status="${_TT_DEVICES}"
        [[ -n "$_TT_ENV" ]] && tmux_status+=" ${_TT_ENV}"
        [[ -n "$_TT_LLM" ]] && tmux_status+=" ●${_TT_LLM}"
        tmux set-option -g status-right " ${tmux_status} " 2>/dev/null
    fi
}

# Save original PS1 before we prepend to it
: "${PS1_BASE:=$PS1}"
export PS1_BASE

PROMPT_COMMAND="_tt_update_prompt${PROMPT_COMMAND:+; $PROMPT_COMMAND}"

# Auto-env on cd
if [[ "${BASH_VERSION:-}" ]]; then
    _tt_orig_cd() { builtin cd "$@" && _tt_check_env; }
    alias cd='_tt_orig_cd'
fi
